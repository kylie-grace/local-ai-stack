# local-ai — environment template
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored and must never be committed.

# ── LiteLLM master key ───────────────────────────────────────────────────────
# Every API client must send: Authorization: Bearer <this value>
# Generate one: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-local-REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-32

# ── GitHub Models API (free tier — gpt-4o, gpt-4o-mini, llama) ──────────────
# Classic Personal Access Token — no special scope needed.
# Create at: https://github.com/settings/tokens (classic)
# If your org uses SAML SSO: click "Configure SSO" → Authorize next to the token.
GITHUB_API_KEY=ghp_REPLACE_ME

# ── GitHub Copilot Enterprise (Claude 4.x, GPT-5.x, Codex) ─────────────────
# OAuth token from the GitHub CLI — NOT a PAT.
# Run: gh auth login (if not already), then: gh auth token
# Token is long-lived. When it expires: gh auth refresh && gh auth token → update here.
# Requires a Copilot Enterprise seat in your org.
COPILOT_TOKEN=REPLACE_ME_WITH_OUTPUT_OF_gh_auth_token

# ── PostgreSQL (internal — never exposed outside Docker) ─────────────────────
# Generate one: openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-16

# ── Anthropic + Gemini ───────────────────────────────────────────────────────
# Both are handled via CLIProxyAPI OAuth login — no API keys needed here.
# After `docker compose up`, open http://localhost:8317/management.html
# and log in to each provider through the UI.
