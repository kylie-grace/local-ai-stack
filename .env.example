# local-ai — environment template
# Copy this to .env and fill in your values:
#   cp .env.example .env
# .env is gitignored — never commit it.

# ── LiteLLM master key ───────────────────────────────────────────────────────
# Every API client must send: Authorization: Bearer <this value>
# Generate: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-local-REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-32

# ── PostgreSQL (internal — never exposed outside Docker) ─────────────────────
# Generate: openssl rand -hex 16
POSTGRES_PASSWORD=REPLACE-WITH-OUTPUT-OF-openssl-rand-hex-16

# ── University of Michigan GPT Toolkit ───────────────────────────────────────
# General API key — used for all umgpt/* models in litellm-config.yaml
# Get your key: https://its.umich.edu/computing/ai/gpt-toolkit-in-depth
# Endpoint: https://api.toolkit.umgpt.umich.edu/v1
# Pricing:  https://its.umich.edu/computing/ai/pricing#toolkit-costs
UMGPT_API_KEY=REPLACE_ME
UMGPT_API_URL=https://api.toolkit.umgpt.umich.edu/v1

# Claude Code API key — separate key for routing Claude Code through LiteLLM (Phase 13)
# Uses base URL without /v1 suffix (Anthropic-compatible endpoint)
UMGPT_CLAUDE_CODE_KEY=REPLACE_ME
UMGPT_CLAUDE_CODE_URL=https://api.toolkit.umgpt.umich.edu
